# Trade Tech Pro server configuration.
# Copy this file to server/.env and fill in the keys you have.
# Any key you leave blank keeps that feature in demo mode (simulated data).

# Anthropic API key — powers the "Pregúntale a TTP" AI assistant.
# Get one at https://platform.claude.com/
ANTHROPIC_API_KEY=

# Google Maps Platform SERVER key — powers address autocomplete (Places API),
# geocoding and property imagery. Keep it server-only (no referrer restriction
# possible). Get one at https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=

# SEPARATE browser key for the in-app map (Maps JavaScript API ONLY, restricted
# by HTTP referrer to your domain). This is the only key ever sent to browsers;
# without it the server key is served as a fallback (unsafe — set this).
GOOGLE_MAPS_BROWSER_KEY=

# Regrid API token — loads real property/parcel boundaries for the fence
# estimator. Get one at https://app.regrid.com/
REGRID_API_KEY=

# RentCast API key — powers property data (bedrooms, baths, sq ft, year built).
# Free tier: 50 lookups/month. Get one at https://app.rentcast.io/app/api
RENTCAST_API_KEY=

# Postgres connection string — persists accounts, leads, sites, sessions.
# Leave blank to run on an in-memory store (data is lost on restart).
DATABASE_URL=

# Admin / team portal keys — gate /admin, /closer, /cs. Pick long secrets.
ADMIN_KEY=
CLOSER_KEY=
CS_KEY=

# Owner-only headquarters (/hq): portfolio numbers, idea board, AI thinking
# partner. Its OWN key — no staff key opens it, not even ADMIN_KEY.
HQ_KEY=

# This business's own domain. LEAVE BLANK and everything serves on the
# onrender/localhost host exactly as in development. Set ROOT_DOMAIN once DNS
# is live (e.g. quickcomp.com) to turn on the bare-domain sales page,
# <slug>.ROOT_DOMAIN client subdomains, and canonical links. APP_HOST is where
# the app/dashboard lives (defaults to app.ROOT_DOMAIN).
ROOT_DOMAIN=
APP_HOST=

# Staff demo pass — ?pass=<value> makes a device's demo unlimited (the /demo
# deck injects it for keyed staff). Pick something unguessable.
DEMO_PASS=

# GoHighLevel inbound bridge secret — /api/hl/lead only accepts posts that
# carry this (query ?key=, header x-alto-key, or body key).
HL_WEBHOOK_SECRET=

# Web push (the lead buzz). Generate once: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Slack/Discord-compatible webhook — pings the team on payments & sales leads.
STAFF_WEBHOOK_URL=

# One-click domain BUY (Cloudflare Registrar) — all optional; without them the
# domain search still works (RDAP, availability only) and buying stays off.
# CF_ACCOUNT_ID + a CF_API_TOKEN with Registrar write permission, plus a
# billing profile with payment method + accepted registration agreement in the
# Cloudflare dashboard (one-time manual setup). CF_REG_* is the registrant
# contact sent with each purchase (phone format: +1.9565551234).
CF_ACCOUNT_ID=
CF_REG_NAME=
CF_REG_ORG=
CF_REG_EMAIL=
CF_REG_PHONE=
CF_REG_STREET=
CF_REG_CITY=
CF_REG_STATE=
CF_REG_ZIP=
CF_REG_COUNTRY=

# Render API — lets the server register bought/connected custom domains with
# the Render service (routing + SSL cert). RENDER_ORIGIN is the host bought
# domains CNAME to (defaults to CF_CNAME_TARGET / APP_HOST).
RENDER_API_KEY=
RENDER_SERVICE_ID=
RENDER_ORIGIN=

# Stripe: one Payment Link per plan + the webhook signing secret.
STRIPE_PAYMENT_LINK=
STRIPE_PAYMENT_LINK_PRO=
STRIPE_PAYMENT_LINK_WIDGET=
STRIPE_WEBHOOK_SECRET=
